#!/usr/bin/env lua

-- Set up package path to include the local lua/ modules.
-- Resolve repo root relative to this script or fall back to CWD.
local function abspath(p)
  local f = io.popen('cd "' .. p .. '" 2>/dev/null && pwd')
  if f then local r = f:read("*l") f:close() return r end
  return p
end
local root = abspath((arg[0]:match("^(.*)/") or "."))
-- If we ended up at scripts/bin/, go up two levels to repo root
if root:match("/scripts/bin$") then
  root = root:gsub("/scripts/bin$", "")
elseif root:match("/scripts$") then
  root = root:gsub("/scripts$", "")
elseif root:match("/bin$") then
  root = root:gsub("/bin$", "")
end
package.path = root .. "/lua/?.lua;" .. root .. "/lua/?/init.lua;" .. package.path

Down = {}

